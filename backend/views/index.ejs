<%- include('partials/header') %>

    <% posts.forEach(post => { %>

    <h2><%= post.title %></h2>

    <p>
    <%= post.content.substring(0,200) %>...
    </p>
    <a href="/new">Create New Blog</a>
    
    <a href="/edit/<%= post.id %>">Edit</a>

    <form action="/delete/<%= post.id %>" method="POST">
    <button type="submit">Delete</button>
    </form>

<hr>

<% }) %> 
                        <%- include('partials/footer') %>