<%- include('partials/header') %>

    <div class="post-card">
        <h2 class="post-title">
            <%= locals.post ? "Edit Post" : "New Post" %>
        </h2>

    <form action="<%= post ? '/edit/' + post.id : '/new' %>" method="POST">

        <div class="form-group">
            <label>Title</label>
            <input type="text" name="title" value="<%= post ? post.title : '' %>" required>
        </div>

        <div class="form-group">
            <label>Content</label>
            <textarea name="content"><%= post ? post.content : '' %></textarea>
        </div>

        <button type="submit">Submit</button>

    </form>
    </div>

    <%- include('partials/footer') %>